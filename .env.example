# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=
db_user=postgres
db_password=
db_host=localhost
db_port=5432
db_name=identity_v_rank

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=15   # Access Token 有效時間（分鐘）— 短期，用於 API 請求
JWT_REFRESH_EXPIRE_DAYS=7      # Refresh Token 有效時間（天）— 長期，用於換發新 Access Token

# ──────────────────────────────────────────────
# Google OAuth2
# 申請位置: https://console.cloud.google.com/apis/credentials
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Discord OAuth2
# 申請位置: https://discord.com/developers/applications
# ──────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
